<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Diario.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             xmlns:avalonia="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             xmlns:controls="clr-namespace:Material.Styles.Controls;assembly=Material.Styles"
             xmlns:dialogHostAvalonia="clr-namespace:DialogHostAvalonia;assembly=DialogHost.Avalonia"
			 xmlns:pages="clr-namespace:Diario.Pages"
			 x:Class="Diario.Views.MainView"
             x:DataType="vm:MainViewModel">
			<UserControl.Resources>
		<ResourceDictionary x:Key="it">
			<x:String x:Key="Home">Il mio diario</x:String>
			<x:String x:Key="Informazioni">Informazioni</x:String>
			<x:String x:Key="RicercaT">Ricerca</x:String>
			<x:String x:Key="Leggi">Leggi il topic</x:String>
			<x:String x:Key="Inserisci">Inserisci il topic</x:String>
			<x:String x:Key="Modifica">Modifica il topic</x:String>
			<x:String x:Key="Elimina">Eliminare il topic</x:String>
			<x:String x:Key="Ricerca">Ricerca tutti i topic fatti dopo la data</x:String>
			<x:String x:Key="RicercaEffettuata">Ricerca effettuata.</x:String>
			<x:String x:Key="CiSono"> Ci sono</x:String>
			<x:String x:Key="elementi">topics. Tornare a Il mio diario per visualizzarli</x:String>
			<x:String x:Key="DatabaseVuoto">La base di dati è vuota</x:String>
			<x:String x:Key="ImpossibileTrovareElementi">La ricerca non ha elementi</x:String>
			<x:String x:Key="Errore">Errore</x:String>
		</ResourceDictionary>
		<ResourceDictionary x:Key="en">
			<x:String x:Key="Home">My own diary</x:String>
			<x:String x:Key="Informazioni">Informations</x:String>
			<x:String x:Key="RicercaT">Search</x:String>
			<x:String x:Key="Leggi">Read topic</x:String>
			<x:String x:Key="Inserisci">Insert topic</x:String>
			<x:String x:Key="Modifica">Modify Topic</x:String>
			<x:String x:Key="Elimina">Delete Topic</x:String>
			<x:String x:Key="Ricerca">Find all topics inserted after the date</x:String>
			<x:String x:Key="RicercaEffettuata">The search has been made.</x:String>
			<x:String x:Key="CiSono"> There are</x:String>
			<x:String x:Key="elementi">topics. Return to My Own Diary to view them.</x:String>
			<x:String x:Key="DatabaseVuoto">Database is empty</x:String>
			<x:String x:Key="ImpossibileTrovareElementi">The search has no topics</x:String>
			<x:String x:Key="Errore">Error</x:String>
		</ResourceDictionary>
		<ResourceDictionary x:Key="es">
			<x:String x:Key="Home">Mi Diario</x:String>
			<x:String x:Key="Informazioni">Información</x:String>
			<x:String x:Key="RicercaT">Búsqueda</x:String>
			<x:String x:Key="Leggi">Leer tema</x:String>
			<x:String x:Key="Inserisci">Insertar tema</x:String>
			<x:String x:Key="Modifica">Modificar tema</x:String>
			<x:String x:Key="Elimina">Eliminar tema</x:String>
			<x:String x:Key="Ricerca">Buscar todos los temas insertados después de la fecha</x:String>
			<x:String x:Key="RicercaEffettuata">La búsqueda se ha realizado.</x:String>
			<x:String x:Key="CiSono">Hay</x:String>
			<x:String x:Key="elementi">temas. Regresa a Mi Diario para verlos.</x:String>
			<x:String x:Key="DatabaseVuoto">La base de datos está vacía</x:String>
			<x:String x:Key="ImpossibileTrovareElementi">La búsqueda no tiene temas</x:String>
			<x:String x:Key="Errore">Error</x:String>
		</ResourceDictionary>
		<ResourceDictionary x:Key="fr">
			<x:String x:Key="Home">Mon Journal</x:String>
			<x:String x:Key="Informazioni">Informations</x:String>
			<x:String x:Key="RicercaT">Rechercher</x:String>
			<x:String x:Key="Leggi">Lire le sujet</x:String>
			<x:String x:Key="Inserisci">Insérer un sujes</x:String>
			<x:String x:Key="Modifica">Modifier le sujet</x:String>
			<x:String x:Key="Elimina">Supprimer le sujet</x:String>
			<x:String x:Key="Ricerca">Rechercher toutes les rubriques insérées après la date</x:String>
			<x:String x:Key="RicercaEffettuata">La recherche a été faite.</x:String>
			<x:String x:Key="CiSono"> Il y a</x:String>
			<x:String x:Key="elementi">Sujets. Retournez à Mon Journal pour les voir.</x:String>
			<x:String x:Key="DatabaseVuoto">La base de données est vide</x:String>
			<x:String x:Key="ImpossibileTrovareElementi">La recherche n’a pas de sujets</x:String>
			<x:String x:Key="Errore">Erreur</x:String>
		</ResourceDictionary>
	</UserControl.Resources>

	  <dialogHostAvalonia:DialogHost Identifier="MainDialogHost">
		   <controls:SnackbarHost HostName="Root">
		  <controls:NavigationDrawer Name="LeftDrawer" Classes="permanent"
									 LeftDrawerOpened="{Binding ElementName=NavDrawerSwitch, Path=IsChecked, Mode=TwoWay}">
			  <controls:NavigationDrawer.LeftDrawerContent>
				  <ScrollViewer>
					  <ListBox Classes="NoScroll" Name="DrawerList"
							   Focusable="{Binding ElementName=LeftDrawer, Path=LeftDrawerOpened}">
						  <ListBox.Styles>
							  <Style Selector="ListBoxItem">
								  <Setter Property="Height" Value="48" />
								  <Setter Property="Padding" Value="16,0" />
								  <Setter Property="VerticalContentAlignment" Value="Center" />
							  </Style>
						  </ListBox.Styles>
						  <ListBoxItem Name="HomeTitle">Home</ListBoxItem>
						  <ListBoxItem Name="RicercaTitle">Search</ListBoxItem>
						  <ListBoxItem Name="InfoTitle">Informations</ListBoxItem>
					  </ListBox>
				  </ScrollViewer>
			  </controls:NavigationDrawer.LeftDrawerContent>
			  <DockPanel LastChildFill="true">
			  	<ToggleButton Name="NavDrawerSwitch" Padding="4" Content="Menu" />
				  <Carousel Name="PageCarousel"
		HorizontalAlignment="Stretch">
					  <Carousel.Styles>
						  <Style Selector="Carousel#PageCarousel:not(.no-transitions)">
							  <Setter Property="PageTransition">
								  <PageSlide Duration="1.00" Orientation="Vertical" SlideOutEasing="QuarticEaseOut"
											 SlideInEasing="QuarticEaseIn" />
							  </Setter>
						  </Style>
					  </Carousel.Styles>
					  <pages:HomePage />
					  <pages:RicercaPage />
					  <pages:InfoPage />
				  </Carousel>
			  </DockPanel>
		  </controls:NavigationDrawer>
		  </controls:SnackbarHost>

	  </dialogHostAvalonia:DialogHost>
</UserControl>
